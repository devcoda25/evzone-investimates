# ============================================================
# EVzone Backend Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# Application
NODE_ENV=development
APP_PORT=3000
APP_NAME=EVzone API
API_PREFIX=api

# Frontend URLs (for CORS)
FRONTEND_INVESTOR_URL=http://localhost:5173
FRONTEND_ENTREPRENEUR_URL=http://localhost:5174
FRONTEND_PROVIDER_URL=http://localhost:5175
FRONTEND_ADMIN_URL=http://localhost:5176

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=evzone
DB_PASSWORD=evzone_secret
DB_NAME=evzone_platform
DB_SSL=false

# Redis (optional - for caching & sessions)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Authentication (legacy - kept for backward compatibility during migration)
JWT_ACCESS_SECRET=your-super-secure-jwt-access-secret-key-change-this
JWT_REFRESH_SECRET=your-super-secure-jwt-refresh-secret-key-change-this
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
JWT_ISSUER=evzone-api
JWT_AUDIENCE=evzone-apps

# OIDC / OAuth2 Provider (MyAccounts)
OIDC_ISSUER=http://localhost:3000/oidc
OIDC_JWKS_URI=http://localhost:3000/oidc/jwks
OIDC_AUDIENCE=evzone-portal

# Password Security
BCRYPT_ROUNDS=12

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# File Upload
UPLOAD_MAX_SIZE=10485760
UPLOAD_DEST=./uploads

# Email (optional - for notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@evzone.com

# Logging
LOG_LEVEL=debug
LOG_FILE_ENABLED=true
