# ============================================================
# EVzone Platform — Environment Configuration
# Copy this file to .env and adjust values for your environment.
# Variables marked [Required] have no safe default and MUST be set.
# Variables marked [Optional] have sensible defaults shown below.
# ============================================================

# ------------------------------------------------------------
# Application Core
# ------------------------------------------------------------
NODE_ENV=development
APP_PORT=3000
APP_NAME="EVzone API"
API_PREFIX=api

# ------------------------------------------------------------
# Frontend URLs (CORS origins)
# ------------------------------------------------------------
FRONTEND_INVESTOR_URL=http://localhost:5173
FRONTEND_ENTREPRENEUR_URL=http://localhost:5174
FRONTEND_ASSESSOR_URL=http://localhost:5175
FRONTEND_ADMIN_URL=http://localhost:5176

# ------------------------------------------------------------
# Database (PostgreSQL)
# [Required] DATABASE_URL is consumed by Prisma and all services.
# DIRECT_URL is used by Prisma for direct (non-pooled) connections.
# ------------------------------------------------------------
DATABASE_URL=postgresql://evzone:evzone_secret@localhost:5432/evzone_platform?schema=public
DIRECT_URL=postgresql://evzone:evzone_secret@localhost:5432/evzone_platform?schema=public

# The following are used by docker-compose.yml for container setup.
# They are NOT read directly by application code.
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=evzone
DB_PASSWORD=evzone_secret
DB_NAME=evzone_platform
DB_SSL=false

# ------------------------------------------------------------
# Redis (cache, rate-limiting, idempotency windows, short locks)
# ------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ------------------------------------------------------------
# Kafka (durable platform events / outbox pattern)
# ------------------------------------------------------------
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=evzone-platform
KAFKA_CONSUMER_GROUP=evzone-worker-events

# The following are used by docker-compose.yml for port mapping only.
KAFKA_INTERNAL_PORT=9092
KAFKA_EXTERNAL_PORT=9094

# ------------------------------------------------------------
# JWT Authentication
# [Required] Secrets MUST be changed in production.
# ------------------------------------------------------------
JWT_ACCESS_SECRET=change-this-access-secret
JWT_REFRESH_SECRET=change-this-refresh-secret
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
JWT_ISSUER=evzone-api
JWT_AUDIENCE=evzone-apps

# ------------------------------------------------------------
# Password Security
# ------------------------------------------------------------
BCRYPT_ROUNDS=12

# ------------------------------------------------------------
# Rate Limiting
# NOTE: Throttle values are currently hard-coded in the API.
#       These variables are reserved for future extraction.
# ------------------------------------------------------------
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ------------------------------------------------------------
# File Upload
# ------------------------------------------------------------
UPLOAD_MAX_SIZE=10485760

# ------------------------------------------------------------
# S3-Compatible Object Storage (MinIO locally)
# ------------------------------------------------------------
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_BUCKET=evzone-assets
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_FORCE_PATH_STYLE=true
STORAGE_SIGNED_URL_TTL_SECONDS=900

# The following are used by docker-compose.yml for port mapping only.
STORAGE_PORT=9000
STORAGE_CONSOLE_PORT=9001

# ============================================================
# LEGACY / UNUSED — Kept for reference but NOT read by active code
# ============================================================
# The variables below are declared in legacy source files under
# the old src/ directory. They are NOT imported by any active
# application under apps/ or libs/. Uncomment if you wire up
# messaging providers in the future.
# ------------------------------------------------------------

# # OIDC compatibility config
# OIDC_ISSUER=http://localhost:3000/oidc
# OIDC_JWKS_URI=http://localhost:3000/oidc/jwks
# OIDC_AUDIENCE=evzone-portal

# # Logging (no logger currently reads these)
# LOG_LEVEL=debug
# LOG_FILE_ENABLED=true

# # Email — SMTP
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@evzone.com

# # Email — SendGrid
# SENDGRID_API_KEY=
# SENDGRID_FROM=noreply@evzone.com

# # Email — Zoho
# ZOHO_SMTP_HOST=smtp.zoho.com
# ZOHO_SMTP_PORT=587
# ZOHO_SMTP_USER=
# ZOHO_SMTP_PASS=
# ZOHO_FROM=noreply@evzone.com

# Logging
LOG_LEVEL=debug
LOG_FILE_ENABLED=true

# KYC Provider
SMILE_IDENTITY_API_KEY=
SMILE_IDENTITY_PARTNER_ID=
SMILE_IDENTITY_WEBHOOK_SECRET=

# Payment Providers
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_WEBHOOK_HASH=
PAYTOTA_SECRET_KEY=
PAYTOTA_WEBHOOK_SECRET=

# # Email — Submail (China)
# SUBMAIL_EMAIL_APP_ID=
# SUBMAIL_EMAIL_APP_KEY=

# # SMS — Twilio
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=

# # SMS — Africa's Talking
# AFRICASTALKING_USERNAME=
# AFRICASTALKING_API_KEY=

