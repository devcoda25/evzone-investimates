# ============================================================
# EVzone Platform - Environment Configuration
# ============================================================
# Derived from env reads in:
# - apps/
# - libs/
# - prisma/schema.prisma
# - docker-compose.yml
# - legacy root src/ references, listed separately at the end
#
# Copy this file to .env and replace secrets before using anything
# outside local development.
# ============================================================

# ------------------------------------------------------------
# Application core
# ------------------------------------------------------------
NODE_ENV=development
APP_PORT=3001
APP_NAME=EVzone API
API_PREFIX=api

# ------------------------------------------------------------
# Frontend URLs used for API CORS
# Active config reads these four app-specific origins.
# ------------------------------------------------------------
FRONTEND_INVESTOR_URL=http://localhost:5173
FRONTEND_ENTREPRENEUR_URL=http://localhost:5174
FRONTEND_ASSESSOR_URL=http://localhost:5175
FRONTEND_ADMIN_URL=http://localhost:3000

# ------------------------------------------------------------
# Database - PostgreSQL / Prisma
# DATABASE_URL is required by prisma/schema.prisma and all active apps.
# DIRECT_URL is passed through Docker workers for direct DB operations.
# ------------------------------------------------------------
DATABASE_URL=postgresql://evzone:evzone_secret@localhost:5432/evzone_platform?schema=public
DIRECT_URL=postgresql://evzone:evzone_secret@localhost:5432/evzone_platform?schema=public

# Docker Compose database setup/interpolation.
DB_PORT=5432
DB_USERNAME=evzone
DB_PASSWORD=evzone_secret
DB_NAME=evzone_platform

# Legacy root src/ seeder reads DB_HOST and DB_SSL. Active apps do not.
DB_HOST=localhost
DB_SSL=false

# ------------------------------------------------------------
# Redis - cache, rate limits, idempotency, short locks
# ------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ------------------------------------------------------------
# Kafka - durable platform events / outbox publisher
# ------------------------------------------------------------
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=evzone-platform
KAFKA_CONSUMER_GROUP=evzone-worker-events

# Docker Compose port mapping.
KAFKA_INTERNAL_PORT=9092
KAFKA_EXTERNAL_PORT=9094

# ------------------------------------------------------------
# JWT authentication
# Required for login, access tokens, refresh tokens, guards, and workers.
# Change both secrets for every non-local environment.
# ------------------------------------------------------------
JWT_ACCESS_SECRET=change-this-access-secret
JWT_REFRESH_SECRET=change-this-refresh-secret
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
JWT_ISSUER=evzone-api
JWT_AUDIENCE=evzone-apps

# ------------------------------------------------------------
# Password security
# ------------------------------------------------------------
BCRYPT_ROUNDS=12

# ------------------------------------------------------------
# File uploads
# ------------------------------------------------------------
UPLOAD_MAX_SIZE=10485760

# ------------------------------------------------------------
# S3-compatible object storage - MinIO locally, S3 in production
# ------------------------------------------------------------
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_BUCKET=evzone-assets
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_FORCE_PATH_STYLE=true
STORAGE_SIGNED_URL_TTL_SECONDS=900

# Docker Compose MinIO port mapping.
STORAGE_PORT=9000
STORAGE_CONSOLE_PORT=9001

# ------------------------------------------------------------
# Notifications - email, SMS, push
# Empty credentials disable those providers in local development.
# ------------------------------------------------------------
SENDGRID_API_KEY=
SENDGRID_FROM=noreply@evzone.com

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@evzone.com

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@evzone.com

# ------------------------------------------------------------
# KYC/KYB provider - Smile Identity
# Empty credentials disable live provider calls/signature checks.
# ------------------------------------------------------------
SMILE_IDENTITY_API_KEY=
SMILE_IDENTITY_PARTNER_ID=
SMILE_IDENTITY_WEBHOOK_SECRET=

# ------------------------------------------------------------
# Payments - provider routing and callbacks
# PAYMENT_DEFAULT_PROVIDER should match the Prisma PaymentProvider enum.
# Current supported providers: FLUTTERWAVE, PAYTOTA.
# ------------------------------------------------------------
PAYMENT_DEFAULT_PROVIDER=FLUTTERWAVE
PAYMENT_CALLBACK_BASE_URL=http://localhost:3001/api/v1/payments/callback

FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_WEBHOOK_HASH=

PAYTOTA_SECRET_KEY=
PAYTOTA_WEBHOOK_SECRET=

# ============================================================
# Reserved / not currently wired in active apps
# ============================================================
# Throttling is currently hard-coded in apps/api/src/app.module.ts.
# LOG_* is not read by active apps/libs today.
# ------------------------------------------------------------
# THROTTLE_TTL=60
# THROTTLE_LIMIT=100
# LOG_LEVEL=debug
# LOG_FILE_ENABLED=true

# ============================================================
# Legacy root src/ only - not used by active Nx apps
# ============================================================
# AGENTS.md marks the root src/ directory as legacy/unused.
# These keys are listed only because they are referenced there.
# Do not set them for the active apps unless that legacy tree is revived.
# ------------------------------------------------------------

# FRONTEND_URL=http://localhost:3000

# OIDC compatibility config used only by legacy root src/ guards.
# OIDC_ISSUER=http://localhost:3000/oidc
# OIDC_JWKS_URI=http://localhost:3000/oidc/jwks
# OIDC_AUDIENCE=evzone-portal

# Email - Zoho
# ZOHO_SMTP_HOST=smtp.zoho.com
# ZOHO_SMTP_PORT=587
# ZOHO_SMTP_USER=
# ZOHO_SMTP_PASS=
# ZOHO_FROM=noreply@evzone.com

# Email - Submail
# SUBMAIL_EMAIL_APP_ID=
# SUBMAIL_EMAIL_APP_KEY=

# SMS - Africa's Talking
# AFRICASTALKING_USERNAME=
# AFRICASTALKING_API_KEY=

# SMS - Submail
# SUBMAIL_SMS_APP_ID=
# SUBMAIL_SMS_APP_KEY=
