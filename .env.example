# ============================================================
# EVzone Backend Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# Application
NODE_ENV=development
APP_PORT=3000
APP_NAME=EVzone API
API_PREFIX=api

# Frontend URLs (for CORS)
FRONTEND_INVESTOR_URL=http://localhost:5173
FRONTEND_ENTREPRENEUR_URL=http://localhost:5174
FRONTEND_ASSESSOR_URL=http://localhost:5175
FRONTEND_ADMIN_URL=http://localhost:5176

# Database (PostgreSQL)
DATABASE_URL=postgresql://evzone:evzone_secret@localhost:5432/evzone_platform?schema=public
DIRECT_URL=postgresql://evzone:evzone_secret@localhost:5432/evzone_platform?schema=public
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=evzone
DB_PASSWORD=evzone_secret
DB_NAME=evzone_platform
DB_SSL=false

# Redis (cache, rate limits, idempotency windows, short locks)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Kafka (durable platform events)
KAFKA_BROKERS=localhost:9094
KAFKA_INTERNAL_PORT=9092
KAFKA_EXTERNAL_PORT=9094
KAFKA_CLIENT_ID=evzone-platform
KAFKA_CONSUMER_GROUP=evzone-worker-events

# JWT Authentication
JWT_ACCESS_SECRET=your-super-secure-jwt-access-secret-key-change-this
JWT_REFRESH_SECRET=your-super-secure-jwt-refresh-secret-key-change-this
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
JWT_ISSUER=evzone-api
JWT_AUDIENCE=evzone-apps

# Optional OIDC compatibility config (not used by primary JWT auth)
OIDC_ISSUER=http://localhost:3000/oidc
OIDC_JWKS_URI=http://localhost:3000/oidc/jwks
OIDC_AUDIENCE=evzone-portal

# Password Security
BCRYPT_ROUNDS=12

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# File Upload
UPLOAD_MAX_SIZE=10485760

# S3-compatible object storage (MinIO locally)
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_PORT=9000
STORAGE_CONSOLE_PORT=9001
STORAGE_REGION=us-east-1
STORAGE_BUCKET=evzone-assets
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_FORCE_PATH_STYLE=true
STORAGE_SIGNED_URL_TTL_SECONDS=900

# Email (optional - for notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@evzone.com

# SendGrid (default email provider for global)
SENDGRID_API_KEY=
SENDGRID_FROM=noreply@evzone.com

# Zoho (alternative email provider)
ZOHO_SMTP_HOST=smtp.zoho.com
ZOHO_SMTP_PORT=587
ZOHO_SMTP_USER=
ZOHO_SMTP_PASS=
ZOHO_FROM=noreply@evzone.com

# Submail (email provider for China)
SUBMAIL_EMAIL_APP_ID=
SUBMAIL_EMAIL_APP_KEY=

# SMS Providers
# Twilio (default SMS provider for global)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# Africa's Talking (SMS provider for Africa)
AFRICASTALKING_USERNAME=
AFRICASTALKING_API_KEY=

# Submail (SMS provider for China)
SUBMAIL_SMS_APP_ID=
SUBMAIL_SMS_APP_KEY=

# Logging
LOG_LEVEL=debug
LOG_FILE_ENABLED=true
# KYC Provider
SMILE_IDENTITY_API_KEY=
SMILE_IDENTITY_PARTNER_ID=
SMILE_IDENTITY_WEBHOOK_SECRET=

# Payment Providers (already documented)
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_WEBHOOK_HASH=
PAYTOTA_SECRET_KEY=
PAYTOTA_WEBHOOK_SECRET=