generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum TenantType {
  PLATFORM
  ORGANIZATION
  INVESTOR_GROUP
  ENTREPRENEUR_COMPANY
  ASSESSOR_FIRM
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum PlatformRole {
  SUPER_ADMIN
  ADMIN
  COMPLIANCE_OFFICER
  INVESTOR
  ENTREPRENEUR
  ASSESSOR
  SUPPORT_AGENT
}

enum MembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
  REMOVED
}

enum UserRole {
  INVESTOR
  ENTREPRENEUR
  ASSESSOR
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING_VERIFICATION
  BLOCKED
}

enum KycStatus {
  NOT_STARTED
  PENDING
  VERIFIED
  REJECTED
}

enum InvestorType {
  INDIVIDUAL
  INSTITUTIONAL
  IMPACT_FUND
  CORPORATE
}

enum RiskTolerance {
  CONSERVATIVE
  MODERATE
  AGGRESSIVE
}

enum EntrepreneurStage {
  IDEA
  MVP
  EARLY_REVENUE
  GROWTH
  SCALE
}

enum AssessorType {
  INDIVIDUAL_CONSULTANT
  FIRM
  NGO
  GOVERNMENT_BODY
  ACADEMIC
}

enum AssessorAvailability {
  AVAILABLE
  BUSY
  ON_LEAVE
}

enum AssessorAccreditationStatus {
  ACCREDITED
  PENDING
  SUSPENDED
  UNDER_REVIEW
}

enum GreenSector {
  SOLAR
  WIND
  HYDRO
  BIOMASS
  EV_CHARGING
  GREEN_HYDROGEN
  ENERGY_STORAGE
  OTHER
}

enum ProjectSector {
  SOLAR
  WIND
  HYDRO
  BIOMASS
  EV_CHARGING
  GREEN_HYDROGEN
  ENERGY_STORAGE
  OTHER
}

enum ProjectStage {
  CONCEPT
  FEASIBILITY
  CONSTRUCTION
  OPERATIONAL
  EXPANSION
}

enum ProjectStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  DUE_DILIGENCE
  APPROVED
  REJECTED
  LISTED
  FUNDING
  FUNDED
  ACTIVE
  COMPLETED
  SUSPENDED
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  OVERDUE
}

enum MediaStatus {
  PENDING_UPLOAD
  UPLOADED
  VALIDATING
  READY
  REJECTED
  DELETED
}

enum MediaPurpose {
  PROJECT_GALLERY
  PROJECT_COVER
  DUE_DILIGENCE_EVIDENCE
  IMPACT_EVIDENCE
  PROFILE_AVATAR
}

enum DocumentPurpose {
  KYC
  KYB
  PITCH_DECK
  DUE_DILIGENCE_REPORT
  DEAL_DOCUMENT
  IMPACT_REPORT
  GENERAL
}

enum DueDiligenceStatus {
  NOT_STARTED
  ASSIGNED
  IN_PROGRESS
  NEEDS_INFORMATION
  REPORT_DRAFTED
  QUALITY_REVIEW
  APPROVED
  REJECTED
  EXPIRED
}

enum DueDiligenceCategory {
  FINANCIAL
  TECHNICAL
  LEGAL
  ESG
  MARKET
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  BLOCKED
  COMPLETED
  CANCELLED
}

enum RiskRating {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum DealStatus {
  DRAFT
  COMPLIANCE_REVIEW
  APPROVED
  LIVE
  PAUSED
  CLOSED_SUCCESSFUL
  CLOSED_FAILED
  CANCELLED
}

enum InvestmentStatus {
  PENDING_COMPLIANCE
  PENDING_PAYMENT
  COMMITTED
  CONFIRMED
  CANCELLED
  REFUNDED
  REJECTED
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  INVESTMENT
  RETURN
  FEE
  REFUND
  LEDGER_POSTING
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
  FLAGGED
  ESCROW
}

enum PaymentMethod {
  BANK_TRANSFER
  CARD
  MOBILE_MONEY
  CRYPTO
}

enum LedgerOwnerType {
  TENANT
  USER
  PROJECT
  DEAL
  PLATFORM
}

enum LedgerDirection {
  DEBIT
  CREDIT
}

enum ComplianceAlertType {
  KYC_ISSUE
  AML_FLAG
  DOCUMENT_EXPIRY
  REGULATORY_CHANGE
  MANUAL_REVIEW
}

enum ComplianceAlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ComplianceAlertStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  DISMISSED
}

enum ComplianceCaseStatus {
  OPEN
  MANUAL_REVIEW
  APPROVED
  REJECTED
  CLOSED
}

enum DisputeType {
  PAYMENT
  PROJECT_DELIVERY
  FRAUD
  COMMUNICATION
  OTHER
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  MEDIATION
  RESOLVED
  ESCALATED
  CLOSED
}

enum NotificationType {
  PROJECT_UPDATE
  INVESTMENT_UPDATE
  DUE_DILIGENCE
  COMPLIANCE
  MESSAGE
  SYSTEM
}

enum OutboxStatus {
  PENDING
  PUBLISHED
  FAILED
}

enum NotificationDispatchStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
}

model Tenant {
  id          String       @id @default(uuid())
  name        String
  slug        String       @unique
  type        TenantType   @default(ORGANIZATION)
  countryCode String?
  status      TenantStatus @default(ACTIVE)

  users       UserTenantMembership[]
  projects    Project[]
  deals       Deal[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id              String     @id @default(uuid())
  email           String     @unique
  phone           String?
  passwordHash    String?
  firstName       String
  lastName        String
  avatar          String?
  status          UserStatus @default(PENDING_VERIFICATION)
  kycStatus       KycStatus  @default(NOT_STARTED)
  mfaEnabled      Boolean    @default(false)
  countryCode     String?
  city            String?
  bio             String?
  riskLevel       RiskRating?
  preferences     Json?
  lastLoginAt     DateTime?
  loginAttempts   Int        @default(0)
  lockoutUntil    DateTime?

  memberships         UserTenantMembership[]
  investorProfile     InvestorProfile?
  entrepreneurProfile EntrepreneurProfile?
  assessorProfile     AssessorProfile?
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  ownedProjects       Project[]          @relation("ProjectOwner")
  investments         Investment[]       @relation("InvestorInvestments")
  notifications       Notification[]
  pushSubscriptions   PushSubscription[]
  sentMessages        Message[]          @relation("MessageSender")
  receivedMessages    Message[]          @relation("MessageRecipient")
  auditLogs           AuditLog[]
  disputes            Dispute[]
  assignedTasks       DueDiligenceTask[] @relation("TaskAssignee")
  watchlistItems      WatchlistItem[]
  activityEvents      ActivityEvent[]
  paymentSchedules    PaymentSchedule[]
  aiChatSessions      AiChatSession[]
  governanceVoteCasts GovernanceVoteCast[]
  kycApplications     KycApplication[]
  kybApplications     KybApplication[]
  complianceCases     ComplianceCase[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  @@index([status])
  @@index([kycStatus])
}

model UserTenantMembership {
  id        String           @id @default(uuid())
  userId    String
  tenantId  String
  role      PlatformRole
  status    MembershipStatus @default(ACTIVE)

  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, tenantId, role])
  @@index([tenantId, role])
  @@index([userId, status])
}

model InvestorProfile {
  id                  String        @id @default(uuid())
  userId              String        @unique
  investorType        InvestorType  @default(INDIVIDUAL)
  riskTolerance       RiskTolerance @default(MODERATE)
  annualIncome        Decimal?      @db.Decimal(18, 2)
  netWorth            Decimal?      @db.Decimal(18, 2)
  accreditationStatus Boolean       @default(false)
  investmentGoals     String[]      @default([])
  preferredSectors    String[]      @default([])
  totalInvested       Decimal       @default(0) @db.Decimal(18, 2)
  totalReturns        Decimal       @default(0) @db.Decimal(18, 2)
  activeInvestments   Int           @default(0)
  completedInvestments Int          @default(0)
  esgPreferences      Json?

  user                User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EntrepreneurProfile {
  id              String            @id @default(uuid())
  userId          String            @unique
  companyName     String
  companyRegistration String?
  companyWebsite  String?
  industry        String
  foundedYear     Int?
  teamSize        Int?
  stage           EntrepreneurStage @default(IDEA)
  pitchDeck       String?
  previousFunding Decimal           @default(0) @db.Decimal(18, 2)
  totalRaised     Decimal           @default(0) @db.Decimal(18, 2)
  activeCampaigns Int               @default(0)
  completedCampaigns Int            @default(0)

  user            User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AssessorProfile {
  id                  String               @id @default(uuid())
  userId              String               @unique
  organizationName    String
  organizationType    AssessorType         @default(FIRM)
  specialties         String[]      @default([])
  credentials         Json?
  yearsOfExperience   Int                  @default(0)
  completedEngagements Int                 @default(0)
  rating              Decimal              @default(0) @db.Decimal(3, 2)
  availabilityStatus  AssessorAvailability @default(AVAILABLE)
  hourlyRate          Decimal?             @db.Decimal(18, 2)
  serviceRegions      String[]      @default([])
  bio                 String?
  licenseExpiry       DateTime?
  insuranceValid      Boolean              @default(false)
  tier                String               @default("Bronze")
  avgTurnaround       Int?
  accreditationStatus AssessorAccreditationStatus @default(PENDING)

  user                User @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedCases       DueDiligenceCase[]   @relation("AssignedAssessor")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RefreshToken {
  id           String    @id @default(uuid())
  userId       String
  tokenHash    String
  expiresAt    DateTime
  revokedAt    DateTime?
  replacedBy   String?
  ipAddress    String?
  userAgent    String?

  user         User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt    DateTime @default(now())

  @@index([userId, expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, expiresAt])
}

model Project {
  id              String        @id @default(uuid())
  tenantId        String
  ownerUserId     String
  title           String
  slug            String
  subtitle        String?
  summary         String
  description     String?
  longDescription String?
  coverImage      String?
  videoUrl        String?
  impactVideo     String?
  story           Json?
  countryCode     String
  country         String
  city            String?
  region          String?
  coordinates     String?
  locationDescription String?
  sector          GreenSector
  stage           ProjectStage
  status          ProjectStatus @default(DRAFT)
  fundingTarget   Decimal       @db.Decimal(18, 2)
  fundingRaised   Decimal       @default(0) @db.Decimal(18, 2)
  minInvestment   Decimal       @default(100) @db.Decimal(18, 2)
  maxInvestment   Decimal?      @db.Decimal(18, 2)
  currency        String        @default("USD")
  equityOffered   Decimal?      @db.Decimal(5, 2)
  valuation       Decimal?      @db.Decimal(18, 2)
  structure       String?
  returnTarget    Decimal?      @db.Decimal(5, 2)
  expectedImpact  Json?
  impactMetrics   Json?
  sdgs            Int[]         @default([])
  risks           Json?
  faqs            Json?
  teamMembers     Json?
  riskRating      RiskRating?
  listedAt        DateTime?
  campaignStartDate DateTime?
  campaignEndDate DateTime?
  projectStartDate DateTime?
  projectEndDate DateTime?
  viewCount       Int           @default(0)
  featured        Boolean       @default(false)
  featuredOrder   Int?
  revisionNotes   String?
  revisionRequestedAt DateTime?
  reviewerId      String?
  environmentalScore Int?
  statusChangedAt DateTime?
  committeeVotes  Json?
  reviewerNotes   Json?

  tenant          Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  owner           User   @relation("ProjectOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)
  milestones      Milestone[]
  gallery         MediaAsset[]
  documents       Document[]
  dueDiligence    DueDiligenceCase?
  deals           Deal[]
  investments     Investment[]
  transactions    Transaction[]
  impactReport    ImpactReport?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  @@unique([tenantId, slug])
  @@index([tenantId, status])
  @@index([countryCode, sector])
  @@index([ownerUserId])
}

model Milestone {
  id          String          @id @default(uuid())
  projectId   String
  title       String
  description String?
  amount      Decimal?        @db.Decimal(18, 2)
  dueDate     DateTime?
  completedAt DateTime?
  verifiedBy  String?
  status      MilestoneStatus @default(PENDING)
  order       Int             @default(0)
  deliverables Json?

  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId, status])
}

model MediaAsset {
  id                  String       @id @default(uuid())
  tenantId            String
  projectId           String?
  ownerUserId         String
  dueDiligenceCaseId  String?
  dueDiligenceTaskId  String?
  bucket              String
  objectKey           String
  publicUrl           String?
  contentType         String
  sizeBytes           Int?
  checksum            String?
  status              MediaStatus  @default(PENDING_UPLOAD)
  purpose             MediaPurpose
  width               Int?
  height              Int?
  altText             String?
  sortOrder           Int          @default(0)

  project             Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  dueDiligenceCase    DueDiligenceCase? @relation("CaseEvidenceMedia", fields: [dueDiligenceCaseId], references: [id], onDelete: SetNull)
  dueDiligenceTask    DueDiligenceTask? @relation(fields: [dueDiligenceTaskId], references: [id], onDelete: SetNull)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([tenantId, projectId])
  @@index([status])
  @@index([dueDiligenceCaseId])
  @@index([dueDiligenceTaskId])
  @@unique([bucket, objectKey])
}

model Document {
  id                  String          @id @default(uuid())
  tenantId            String
  ownerUserId         String
  projectId           String?
  mediaAssetId        String?
  dueDiligenceCaseId  String?
  dueDiligenceTaskId  String?
  originalName        String
  contentType         String
  sizeBytes           Int?
  bucket              String
  objectKey           String
  purpose             DocumentPurpose @default(GENERAL)
  status              MediaStatus     @default(PENDING_UPLOAD)
  deletedAt           DateTime?

  project             Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  dueDiligenceCase    DueDiligenceCase? @relation("CaseEvidenceDocuments", fields: [dueDiligenceCaseId], references: [id], onDelete: SetNull)
  dueDiligenceTask    DueDiligenceTask? @relation(fields: [dueDiligenceTaskId], references: [id], onDelete: SetNull)
  finalReportForCases DueDiligenceCase? @relation("CaseFinalReport")

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([tenantId, ownerUserId])
  @@index([projectId])
  @@index([dueDiligenceCaseId])
  @@index([dueDiligenceTaskId])
  @@unique([bucket, objectKey])
}

model DueDiligenceCase {
  id              String             @id @default(uuid())
  tenantId        String
  projectId       String             @unique
  assignedAssessorId String?
  status          DueDiligenceStatus @default(NOT_STARTED)
  riskScore       Int?
  riskRating      RiskRating?
  summary         String?
  finalReportDocumentId String? @unique
  assignedAt      DateTime?
  startedAt       DateTime?
  submittedAt     DateTime?
  reviewedAt      DateTime?
  dueAt           DateTime?
  notes           String?
  assessments     Json?

  project         Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignedAssessor    AssessorProfile?  @relation("AssignedAssessor", fields: [assignedAssessorId], references: [userId], onDelete: SetNull)
  tasks               DueDiligenceTask[]
  evidenceDocuments   Document[]        @relation("CaseEvidenceDocuments")
  evidenceMedia       MediaAsset[]      @relation("CaseEvidenceMedia")
  finalReportDocument Document?         @relation("CaseFinalReport", fields: [finalReportDocumentId], references: [id], onDelete: SetNull)

  createdAt           DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId, status])
  @@index([assignedAssessorId])
}

model DueDiligenceTask {
  id               String               @id @default(uuid())
  caseId           String
  category         DueDiligenceCategory
  title            String
  status           TaskStatus           @default(OPEN)
  assignedToUserId String?
  dueAt            DateTime?
  notes            String?

  case             DueDiligenceCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  assignedTo       User?            @relation("TaskAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  evidenceDocuments Document[]
  evidenceMedia    MediaAsset[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([caseId, status])
  @@index([assignedToUserId])
}

model Deal {
  id              String     @id @default(uuid())
  tenantId        String
  projectId       String
  title           String
  status          DealStatus @default(DRAFT)
  currency        String     @default("USD")
  minInvestment   Decimal    @db.Decimal(18, 2)
  targetAmount    Decimal    @db.Decimal(18, 2)
  maxAmount       Decimal?   @db.Decimal(18, 2)
  opensAt         DateTime?
  closesAt        DateTime?

  tenant          Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  project         Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  investments     Investment[]
  watchlistItems  WatchlistItem[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId, status])
  @@index([projectId])
}

model Investment {
  id              String           @id @default(uuid())
  tenantId        String
  dealId          String?
  projectId       String
  investorUserId  String
  amount          Decimal          @db.Decimal(18, 2)
  currency        String
  status          InvestmentStatus @default(PENDING_COMPLIANCE)
  idempotencyKey  String
  paymentMethod   PaymentMethod?
  confirmedAt     DateTime?

  deal            Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Restrict)
  investor        User     @relation("InvestorInvestments", fields: [investorUserId], references: [id], onDelete: Restrict)
  transactions    Transaction[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([investorUserId, idempotencyKey])
  @@index([tenantId, projectId])
  @@index([investorUserId, status])
}

model Transaction {
  id              String            @id @default(uuid())
  tenantId        String
  userId          String
  investmentId    String?
  projectId       String?
  type            TransactionType
  amount          Decimal           @db.Decimal(18, 2)
  currency        String            @default("USD")
  status          TransactionStatus @default(PENDING)
  paymentMethod   PaymentMethod?
  paymentProvider String?
  providerTransactionId String?
  riskScore       Int?
  jurisdiction    String?
  metadata        Json?
  processedAt     DateTime?

  investment      Investment? @relation(fields: [investmentId], references: [id], onDelete: SetNull)
  project         Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId, status])
  @@index([userId])
  @@index([projectId])
}

model LedgerAccount {
  id          String          @id @default(uuid())
  tenantId    String
  ownerType   LedgerOwnerType
  ownerId     String
  currency    String
  name        String

  entries     LedgerEntry[]

  createdAt   DateTime @default(now())

  @@unique([tenantId, ownerType, ownerId, currency, name])
}

model LedgerEntry {
  id              String          @id @default(uuid())
  tenantId        String
  accountId       String
  transactionId   String
  direction       LedgerDirection
  amount          Decimal         @db.Decimal(18, 2)
  currency        String
  memo            String?

  account         LedgerAccount @relation(fields: [accountId], references: [id], onDelete: Restrict)

  createdAt       DateTime @default(now())

  @@index([tenantId, transactionId])
  @@index([accountId])
}

enum PaymentProvider {
  FLUTTERWAVE
  PAYTOTA
}

enum PaymentDirection {
  COLLECTION
  PAYOUT
  REFUND
}

enum PaymentPurpose {
  INVESTMENT_FUNDING
  INVESTOR_TOPUP
  PROJECT_REPAYMENT
  INVESTOR_DISTRIBUTION
  ASSESSOR_FEE
  PLATFORM_FEE
  REFUND
}

enum PaymentStatus {
  PENDING
  REQUIRES_ACTION
  PROCESSING
  SUCCEEDED
  FAILED
  CANCELLED
  EXPIRED
}

enum WebhookProcessingStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
  IGNORED
}

enum PayoutDestinationType {
  BANK_ACCOUNT
  MOBILE_MONEY
  WALLET
}

enum KycProvider {
  SMILE_IDENTITY
  ONFIDO
  GENERIC
}

enum KycApplicationStatus {
  PENDING
  SUBMITTED
  PROCESSING
  VERIFIED
  REJECTED
}

enum IdDocumentType {
  PASSPORT
  NATIONAL_ID
  DRIVERS_LICENSE
  RESIDENCE_PERMIT
  BUSINESS_REGISTRATION
  TAX_DOCUMENT
}

model PaymentIntent {
  id                    String   @id @default(uuid())
  tenantId              String
  investmentId          String?
  dealId                String?
  userId                String?

  provider              PaymentProvider
  direction             PaymentDirection
  purpose               PaymentPurpose

  internalReference     String   @unique
  providerReference     String?
  providerTransactionId String?

  amount                Decimal  @db.Decimal(18, 2)
  currency              String

  status                PaymentStatus @default(PENDING)
  checkoutUrl           String?
  expiresAt             DateTime?

  metadata              Json?
  rawProviderResponse   Json?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  transactions          PaymentTransaction[]

  @@index([tenantId, status])
  @@index([provider, providerReference])
  @@index([investmentId])
}

model PaymentTransaction {
  id                    String   @id @default(uuid())
  tenantId              String
  paymentIntentId       String

  provider              PaymentProvider
  providerTransactionId String?
  providerReference     String?

  amount                Decimal  @db.Decimal(18, 2)
  currency              String
  status                PaymentStatus

  providerStatus        String?
  providerFeeAmount     Decimal? @db.Decimal(18, 2)
  netAmount             Decimal? @db.Decimal(18, 2)

  verifiedAt            DateTime?
  settledAt             DateTime?

  rawProviderResponse   Json?

  paymentIntent         PaymentIntent @relation(fields: [paymentIntentId], references: [id], onDelete: Cascade)

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([tenantId, status])
  @@index([provider, providerTransactionId])
}

model PaymentWebhookEvent {
  id                String   @id @default(uuid())
  provider          PaymentProvider
  providerEventId   String?
  eventType         String
  signature         String?
  rawBody           String
  payload           Json

  processingStatus  WebhookProcessingStatus @default(PENDING)
  processedAt       DateTime?
  errorMessage      String?

  createdAt         DateTime @default(now())

  @@unique([provider, providerEventId])
  @@index([provider, eventType])
  @@index([processingStatus])
}

model Payout {
  id                    String   @id @default(uuid())
  tenantId              String
  userId                String?
  organizationId        String?

  provider              PaymentProvider
  internalReference     String   @unique
  providerPayoutId      String?
  providerReference     String?

  amount                Decimal  @db.Decimal(18, 2)
  currency              String
  destinationType       PayoutDestinationType
  destinationMasked     String

  status                PaymentStatus @default(PENDING)

  rawProviderResponse   Json?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([tenantId, status])
  @@index([provider, providerPayoutId])
}

model KycApplication {
  id                String                @id @default(uuid())
  tenantId          String
  userId            String
  provider          KycProvider
  providerReference String?
  status            KycApplicationStatus  @default(PENDING)

  idType            IdDocumentType?
  idNumber          String?
  idExpiryDate      DateTime?
  nationality       String?
  dateOfBirth       DateTime?

  submittedData     Json?
  providerResult    Json?
  verificationScore Decimal?              @db.Decimal(5, 2)

  verifiedAt        DateTime?
  rejectedAt        DateTime?
  rejectionReason   String?

  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  user              User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([userId, status])
  @@index([provider, providerReference])
}

model KybApplication {
  id                    String                @id @default(uuid())
  tenantId              String
  userId                String?
  organizationName      String
  registrationNumber    String?
  incorporationDate     DateTime?
  jurisdiction          String?

  provider              KycProvider           @default(GENERIC)
  providerReference     String?
  status                KycApplicationStatus  @default(PENDING)

  directors             Json?
  beneficialOwners      Json?
  submittedDocuments    Json?
  providerResult        Json?
  verificationScore     Decimal?              @db.Decimal(5, 2)

  verifiedAt            DateTime?
  rejectedAt            DateTime?
  rejectionReason       String?

  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  user                  User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, status])
  @@index([userId, status])
  @@index([provider, providerReference])
}

model ComplianceAlert {
  id          String                    @id @default(uuid())
  tenantId    String
  type        ComplianceAlertType
  severity    ComplianceAlertSeverity
  status      ComplianceAlertStatus     @default(OPEN)
  entityType  String
  entityId    String
  title       String
  description String
  assignedTo  String?
  resolutionNotes String?
  resolvedAt  DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, status])
  @@index([severity])
}

model ComplianceCase {
  id          String               @id @default(uuid())
  tenantId    String
  userId      String?
  organizationId String?
  dealId      String?
  status      ComplianceCaseStatus @default(OPEN)
  riskRating  RiskRating?
  reason      String?
  metadata    Json?
  decidedAt   DateTime?
  decidedBy   String?

  user        User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, status])
  @@index([userId])
}

model Dispute {
  id          String        @id @default(uuid())
  tenantId    String
  type        DisputeType
  status      DisputeStatus @default(OPEN)
  title       String
  description String
  initiatorId String
  entityType  String?
  entityId    String?
  evidence    Json?
  resolution  String?
  resolvedAt  DateTime?
  priority    String?   @default("medium")
  financialImpact Decimal? @db.Decimal(18, 2)
  assignedTo  String?

  initiator   User @relation(fields: [initiatorId], references: [id], onDelete: Restrict)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, status])
  @@index([initiatorId])
}

model AuditLog {
  id          String   @id @default(uuid())
  tenantId    String?
  userId      String?
  action      String
  entityType  String
  entityId    String
  oldValues   Json?
  newValues   Json?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  jurisdiction String?

  user        User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())

  @@index([tenantId, action])
  @@index([entityType, entityId])
  @@index([userId])
}

model Notification {
  id          String           @id @default(uuid())
  tenantId    String?
  userId      String
  type        NotificationType
  title       String
  message     String
  data        Json?
  readAt      DateTime?
  channels    String[]         @default([])

  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@index([userId, readAt])
}

model NotificationDispatch {
  id                String                     @id @default(uuid())
  eventKey          String                     @unique
  eventType         String
  payload           Json
  status            NotificationDispatchStatus @default(PENDING)
  attempts          Int                        @default(0)
  lastError         String?
  nextAttemptAt     DateTime?
  processingStartedAt DateTime?
  processedAt       DateTime?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  @@index([status, nextAttemptAt, createdAt])
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String
  p256dh    String
  auth      String
  userAgent String?

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@unique([userId, endpoint])
}

model Message {
  id          String   @id @default(uuid())
  senderId    String
  recipientId String
  subject     String?
  body        String
  attachments Json?
  readAt      DateTime?

  sender      User @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipient   User @relation("MessageRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@index([senderId])
  @@index([recipientId, readAt])
}

model OutboxEvent {
  id              String       @id @default(uuid())
  tenantId        String?
  topic           String
  eventType       String
  aggregateType   String
  aggregateId     String
  eventKey        String       @unique
  payload         Json
  status          OutboxStatus @default(PENDING)
  attempts        Int          @default(0)
  lastError       String?
  nextAttemptAt   DateTime?
  publishedAt     DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status, createdAt])
  @@index([status, nextAttemptAt, createdAt])
  @@index([aggregateType, aggregateId])
}
model WatchlistItem {
  id        String   @id @default(uuid())
  userId    String
  dealId    String
  tenantId  String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@unique([userId, dealId])
  @@index([userId])
  @@index([tenantId])
}

model ActivityEvent {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String
  type      String   // investment | document | alert | payment | message | system
  title     String
  detail    String
  metadata  Json?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([tenantId])
}

model PaymentSchedule {
  id            String   @id @default(uuid())
  tenantId      String
  userId        String
  investmentId  String?
  dealId        String?
  projectId     String?
  amount        Decimal  @db.Decimal(18, 2)
  currency      String   @default("USD")
  dueDate       DateTime
  status        String   @default("scheduled") // scheduled | pending | paid | overdue | cancelled
  type          String   // distribution | capital_call | dividend | interest | revenue_share
  description   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([dueDate])
  @@index([tenantId])
}

model GovernanceVote {
  id          String   @id @default(uuid())
  tenantId    String
  projectId   String
  title       String
  description String
  status      String   @default("open") // open | closed
  deadline    DateTime
  quorum      Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  casts       GovernanceVoteCast[]

  @@index([projectId, status])
  @@index([tenantId, status])
}

model GovernanceVoteCast {
  id        String         @id @default(uuid())
  voteId    String
  userId    String
  choice    String         // for | against | abstain
  createdAt DateTime       @default(now())

  vote      GovernanceVote @relation(fields: [voteId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([voteId, userId])
  @@index([voteId])
}

model AiChatSession {
  id        String   @id @default(uuid())
  userId    String
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  AiChatMessage[]

  @@index([userId])
}

model AiChatMessage {
  id        String   @id @default(uuid())
  sessionId String
  role      String   // user | ai
  text      String
  createdAt DateTime @default(now())

  session   AiChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model ImpactReport {
  id              String   @id @default(uuid())
  tenantId        String
  projectId       String   @unique
  submittedBy     String
  reportingPeriodStart DateTime
  reportingPeriodEnd   DateTime
  metrics         Json?
  evidenceAttachments Json?
  notes           String?
  status          ImpactReportStatus @default(SUBMITTED)
  submittedAt     DateTime @default(now())
  reviewedAt      DateTime?
  reviewedBy      String?
  reviewNotes     String?

  project         Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
}

enum ImpactReportStatus {
  SUBMITTED
  VERIFIED
  REJECTED
}

model EncryptedField {
  id          String   @id @default(uuid())
  tenantId    String
  entityType  String
  entityId    String
  fieldName   String
  encryptedValue String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([entityType, entityId, fieldName])
  @@index([tenantId])
}
