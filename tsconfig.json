{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "paths": {
      "@evzone/common": ["libs/common/src/index.ts"],
      "@evzone/config": ["libs/config/src/index.ts"],
      "@evzone/database": ["libs/database/src/index.ts"],
      "@evzone/auth": ["libs/auth/src/index.ts"],
      "@evzone/permissions": ["libs/permissions/src/index.ts"],
      "@evzone/events": ["libs/events/src/index.ts"],
      "@evzone/redis": ["libs/redis/src/index.ts"],
      "@evzone/storage": ["libs/storage/src/index.ts"],
      "@evzone/audit": ["libs/audit/src/index.ts"],
      "@evzone/encryption": ["libs/encryption/src/index.ts"],
      "@evzone/impact": ["libs/impact/src/index.ts"],
      "@evzone/notifications": ["libs/notifications/src/index.ts"]
    }
  },
  "include": ["apps/**/*.ts", "libs/**/*.ts", "prisma/**/*.ts", "test/**/*.ts"],
  "exclude": ["node_modules", "dist", "coverage"]
}
