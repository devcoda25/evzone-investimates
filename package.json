{
  "name": "evzone-backend",
  "version": "1.0.0",
  "description": "EVzone Global Green Finance Platform — modular NestJS backend for Investor, Entrepreneur, Assessor, and Admin applications",
  "author": "EVzone",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "nx run-many -t build --projects=api,worker-events,worker-media,worker-compliance,scheduler,worker-notifications,worker-webhooks",
    "build:api": "nx build api",
    "format": "prettier --write \"{apps,libs,prisma,test}/**/*.ts\" \"*.json\"",
    "start": "node dist/apps/api/src/main.js",
    "start:dev": "ts-node -r tsconfig-paths/register apps/api/src/main.ts",
    "start:worker-events": "node dist/apps/worker-events/src/main.js",
    "start:worker-media": "node dist/apps/worker-media/src/main.js",
    "start:worker-compliance": "node dist/apps/worker-compliance/src/main.js",
    "start:scheduler": "node dist/apps/scheduler/src/main.js",
    "start:worker-notifications": "node dist/apps/worker-notifications/src/main.js",
    "start:worker-webhooks": "node dist/apps/worker-webhooks/src/main.js",
    "seed": "ts-node -r tsconfig-paths/register prisma/seed.ts",
    "lint": "eslint \"{apps,libs,prisma,test}/**/*.ts\"",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.577.0",
    "@aws-sdk/s3-request-presigner": "^3.577.0",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/mapped-types": "^2.0.4",
    "@nestjs/microservices": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/swagger": "^7.2.0",
    "@nestjs/throttler": "^5.1.1",
    "@prisma/client": "^5.22.0",
    "@sendgrid/mail": "^8.1.6",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "compression": "^1.7.4",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "kafkajs": "^2.2.4",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.7",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.0",
    "twilio": "^6.0.2",
    "uuid": "^9.0.1",
    "web-push": "^3.6.7",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.3.0",
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.7.5",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.6",
    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.7",
    "@types/web-push": "^3.6.4",
    "@typescript-eslint/eslint-plugin": "^6.16.0",
    "@typescript-eslint/parser": "^6.16.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.2",
    "jest": "^29.7.0",
    "nx": "^20.3.0",
    "prettier": "^3.1.1",
    "prisma": "^5.22.0",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testMatch": [
      "<rootDir>/test/**/*.spec.ts",
      "<rootDir>/apps/**/*.spec.ts",
      "<rootDir>/libs/**/*.spec.ts"
    ],
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "moduleNameMapper": {
      "^@evzone/common$": "<rootDir>/libs/common/src",
      "^@evzone/config$": "<rootDir>/libs/config/src",
      "^@evzone/database$": "<rootDir>/libs/database/src",
      "^@evzone/auth$": "<rootDir>/libs/auth/src",
      "^@evzone/permissions$": "<rootDir>/libs/permissions/src",
      "^@evzone/events$": "<rootDir>/libs/events/src",
      "^@evzone/redis$": "<rootDir>/libs/redis/src",
      "^@evzone/storage$": "<rootDir>/libs/storage/src",
      "^@evzone/audit$": "<rootDir>/libs/audit/src",
      "^@evzone/notifications$": "<rootDir>/libs/notifications/src"
    },
    "collectCoverageFrom": [
      "apps/**/*.ts",
      "libs/**/*.ts"
    ],
    "coverageDirectory": "coverage",
    "testEnvironment": "node"
  }
}
